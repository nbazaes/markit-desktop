# Maintainer: MarkItDown GUI Contributors

pkgname=markitdown-gui
pkgver=0.1.0
pkgrel=1
pkgdesc="Modern cross-platform GUI for MarkItDown file-to-Markdown converter"
arch=('any')
url="https://github.com/microsoft/markitdown"
license=('MIT')
depends=('python>=3.10' 'python-pyside6')
makedepends=('python-build' 'python-installer' 'python-hatchling')
optdepends=(
    'python-pdfplumber: PDF support'
    'python-pandas: XLSX/XLS support'
    'python-openpyxl: XLSX support'
    'python-pptx: PPTX support'
    'python-lxml: DOCX support'
    'python-pydub: Audio transcription'
    'python-SpeechRecognition: Audio transcription'
)

source=("${pkgname}-${pkgver}.tar.gz::https://github.com/microsoft/markitdown/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/markitdown-${pkgver}/markitdown-gui"
    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/markitdown-${pkgver}/markitdown-gui"
    python -m installer --destdir="${pkgdir}" dist/*.whl
}

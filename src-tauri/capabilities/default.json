{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
"permissions": [
        "core:default",
        "dialog:default",
        "log:default",
        "shell:allow-open",
        "shell:allow-execute",
        "shell:allow-spawn",
        "shell:allow-stdin-write",
        "shell:allow-kill",
        "fs:default"
    ]
}
